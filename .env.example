# Inkstone Configuration
# Copy to .env and adjust.

DATABASE_URL=postgres://inkstone:inkstone@localhost:5432/inkstone
HOST=0.0.0.0
PORT=8080

# Auth mode
# true = dev mode with x-dev-user-id header
# false = OIDC mode (requires OIDC_* vars)
DEV_AUTH=true

# OIDC (only needed when DEV_AUTH=false)
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret

LOG_LEVEL=info
